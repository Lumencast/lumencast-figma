{
  "name": "lumencast-figma",
  "version": "0.1.0-pre.0",
  "description": "Lumencast Export — Figma plugin for LSML 1.1 scene bundles (export + import)",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Lumencast/lumencast-figma",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lumencast/lumencast-figma.git"
  },
  "bugs": {
    "url": "https://github.com/Lumencast/lumencast-figma/issues"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm build:main && pnpm build:ui",
    "build:main": "cross-env BUILD_TARGET=main vite build",
    "build:ui": "cross-env BUILD_TARGET=ui vite build",
    "dev": "pnpm build:main && cross-env BUILD_TARGET=ui vite build --watch",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "node scripts/package.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "clean": "rimraf dist coverage .vitest *.tsbuildinfo lumencast-figma-*.zip"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@figma/plugin-typings": "^1.108.0",
    "@preact/preset-vite": "^2.10.1",
    "@preact/signals": "^2.0.1",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^3.0.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.6.0",
    "happy-dom": "^17.1.0",
    "preact": "^10.25.4",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^3.0.5"
  }
}
